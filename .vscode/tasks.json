{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Run Pester Tests",
            "type": "shell",
            "command": "pwsh",
            "args": ["-NoProfile", "-Command", "Invoke-Pester ${workspaceFolder}/tests/Toolkit.Tests.ps1"],
            "group": "test",
            "presentation": { "reveal": "always", "panel": "dedicated" }
        },
        {
            "label": "Install / Update Dotfiles",
            "type": "shell",
            "command": "pwsh",
            "args": ["-NoProfile", "-File", "${userHome}/.config/powershell/install.ps1"],
            "group": "none",
            "presentation": { "reveal": "always" }
        },
        {
            "label": "Update Dotfiles (git pull)",
            "type": "shell",
            "command": "pwsh",
            "args": ["-NoProfile", "-File", "${userHome}/.config/powershell/update.ps1"],
            "group": "none",
            "presentation": { "reveal": "always" }
        },
        {
            "label": "Generate WT Fragment",
            "type": "shell",
            "command": "pwsh",
            "args": ["-NoProfile", "-File", "${workspaceFolder}/scripts/Add-WTProfiles.ps1"],
            "group": "none",
            "presentation": { "reveal": "always" }
        },
        {
            "label": "Install Dependencies",
            "type": "shell",
            "command": "pwsh",
            "args": ["-NoProfile", "-File", "${workspaceFolder}/scripts/deps.ps1"],
            "group": "none",
            "presentation": { "reveal": "always" }
        }
    ]
}
